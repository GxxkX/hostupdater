FROM ubuntu:22.04

ENV DEBIAN_FRONTEND=noninteractive

# Install base dependencies
RUN sed -i 's|archive.ubuntu.com|mirrors.tuna.tsinghua.edu.cn|g; s|security.ubuntu.com|mirrors.tuna.tsinghua.edu.cn|g' /etc/apt/sources.list && \
    apt-get update && apt-get install -y --no-install-recommends \
    build-essential \
    ccache \
    ecj \
    fastjar \
    file \
    g++ \
    gawk \
    gettext \
    git \
    libelf-dev \
    libncurses5-dev \
    libncursesw5-dev \
    libssl-dev \
    python3 \
    python3-dev \
    python3-setuptools \
    rsync \
    unzip \
    wget \
    xsltproc \
    zlib1g-dev \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /build

ARG SDK_URL
ARG OPENWRT_VERSION

# OpenWrt 19.07 and 21.02 require Python 2.x for SDK build system
# Ubuntu 22.04 dropped Python 2, so we need to get it from older repos
# Also install quilt, subversion, and other legacy dependencies
RUN apt-get update && apt-get install -y software-properties-common && \
    add-apt-repository -y ppa:deadsnakes/ppa && \
    apt-get update && apt-get install -y --no-install-recommends \
    python2 python2-dev \
    quilt \
    subversion \
    asciidoc \
    binutils \
    bzip2 \
    flex \
    gzip \
    libc6-dev \
    libgmp3-dev \
    libmpc-dev \
    libmpfr-dev \
    libsigsegv-dev \
    m4 \
    make \
    patch \
    perl \
    perl-modules \
    texinfo \
    && ln -sf /usr/bin/python2 /usr/bin/python && \
    rm -rf /var/lib/apt/lists/*

# Download and extract SDK (detect .zst vs .xz from URL)
RUN SDK_FILE=$(basename "${SDK_URL}") && \
    echo "Downloading SDK for OpenWrt ${OPENWRT_VERSION}..." && \
    wget -q "${SDK_URL}" -O "${SDK_FILE}" && \
    if echo "${SDK_FILE}" | grep -q "\.tar\.zst$"; then \
        echo "Extracting .tar.zst SDK..." && \
        apt-get update && apt-get install -y --no-install-recommends zstd && rm -rf /var/lib/apt/lists/* && \
        tar --zstd -xf "${SDK_FILE}" && \
        rm "${SDK_FILE}"; \
    else \
        echo "Extracting .tar.xz SDK..." && \
        tar -xf "${SDK_FILE}" && \
        rm "${SDK_FILE}"; \
    fi && \
    mv openwrt-sdk-* sdk

WORKDIR /build/sdk

# Copy package source
COPY ./Makefile ./package/hostupdater/
COPY ./files/ ./package/hostupdater/files/
COPY ./luasrc/ ./package/hostupdater/luasrc/
COPY ./po/ ./package/hostupdater/po/
COPY ./LICENSE ./package/hostupdater/

# Build the package
RUN make defconfig 2>&1 | tee /tmp/defconfig.log && \
    make package/hostupdater/compile V=s -j$(nproc) 2>&1 | tee /tmp/compile.log || { \
        echo "Build failed, saving log..."; \
        cp /tmp/compile.log /build/sdk/bin/compile.log 2>/dev/null || true; \
        exit 1; \
    }

CMD ["find", "/build/sdk/bin", "-name", "*.ipk", "-o", "-name", "*.apk"]
